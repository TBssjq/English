<?xml version="1.0" encoding="utf-8"?>
<!--
    自定义学习状态通知布局（RemoteViews）
    - 紧凑展示：当前单词 + 进度条 + 3 个操作按钮（发音/不认识/认识）
    - 通过 values/colors.xml + values-night/colors.xml 自动适配深色模式
    - 布局故意保持精简：RemoteViews 仅支持有限视图，避免复杂嵌套
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/notif_bg"
    android:padding="16dp">

    <!-- 顶部：单词 + 进度文本 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tv_word"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/notif_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:text="abandon"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_progress_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/notif_text_secondary"
            android:textSize="13sp"
            android:text="3 / 20" />
    </LinearLayout>

    <!-- 音标 + 释义 -->
    <TextView
        android:id="@+id/tv_phonetic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/notif_text_secondary"
        android:textSize="13sp"
        android:text="/əˈbændən/"
        android:layout_marginBottom="2dp" />

    <TextView
        android:id="@+id/tv_translation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/notif_text_secondary"
        android:textSize="14sp"
        android:text="v. 放弃；抛弃"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginBottom="10dp" />

    <!-- 进度条 -->
    <ProgressBar
        android:id="@+id/pb_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:max="100"
        android:progress="15"
        android:progressTint="@color/notif_btn_right_bg"
        android:progressBackgroundTint="@color/notif_progress_track"
        android:layout_marginBottom="14dp" />

    <!-- 三个操作按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 发音 -->
        <Button
            android:id="@+id/btn_speak"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@color/notif_btn_speak_bg"
            android:textColor="@color/notif_btn_speak_text"
            android:textSize="13sp"
            android:text="🔊 发音"
            android:stateListAnimator="@null"
            android:layout_marginEnd="8dp" />

        <!-- 不认识 -->
        <Button
            android:id="@+id/btn_wrong"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@color/notif_btn_wrong_bg"
            android:textColor="@color/notif_btn_wrong_text"
            android:textSize="13sp"
            android:text="✕ 不认识"
            android:stateListAnimator="@null"
            android:layout_marginEnd="8dp" />

        <!-- 认识 / 下一个 -->
        <Button
            android:id="@+id/btn_known"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@color/notif_btn_right_bg"
            android:textColor="@color/notif_btn_right_text"
            android:textSize="13sp"
            android:text="✓ 认识"
            android:stateListAnimator="@null" />
    </LinearLayout>
</LinearLayout>
