<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="horizontal"
    android:background="@color/notif_bg"
    android:padding="12dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_word"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/notif_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:text="abandon"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_progress_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/notif_text_secondary"
                android:textSize="12sp"
                android:text="3/20"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_phonetic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/notif_text_secondary"
            android:textSize="12sp"
            android:text="/əˈbændən/"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="8dp">

        <Button
            android:id="@+id/btn_speak"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@color/notif_btn_speak_bg"
            android:textColor="@color/notif_btn_speak_text"
            android:textSize="18sp"
            android:text="🔊"
            android:stateListAnimator="@null"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btn_wrong"
            android:layout_width="48dp"
            android:layout_height="36dp"
            android:background="@color/notif_btn_wrong_bg"
            android:textColor="@color/notif_btn_wrong_text"
            android:textSize="13sp"
            android:text="✕"
            android:stateListAnimator="@null"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btn_known"
            android:layout_width="48dp"
            android:layout_height="36dp"
            android:background="@color/notif_btn_right_bg"
            android:textColor="@color/notif_btn_right_text"
            android:textSize="13sp"
            android:text="✓"
            android:stateListAnimator="@null" />
    </LinearLayout>
</LinearLayout>